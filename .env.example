APP_ENV=dev
LOG_LEVEL=INFO

# Telegram bot token
BOT_TOKEN=123456:ABCDEF

# Public URL where Telegram Web App is served from (used for CORS)
WEBAPP_URL=http://localhost:5173

# Postgres
DB_USER=ppl
DB_PASS=ppl
DB_NAME=ppl

# Internal token for bot<->api calls
INTERNAL_API_TOKEN=change-me

# Comma-separated Telegram user IDs with admin rights
ADMINS=463768684

# For local dev without Telegram initData (DO NOT enable in production)
ALLOW_DEBUG_AUTH=true

# Web build-time API base URL (optional)
VITE_API_BASE_URL=http://localhost:8000

